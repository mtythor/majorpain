# Database (required for API routes)
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/major_pain

# Auth (required for per-player login)
JWT_SECRET=your-long-random-secret-at-least-16-chars

# Optional: Initial password for seed-users (default: ChangeMe123)
MAJOR_PAIN_INITIAL_PASSWORD=ChangeMe123

# Write secret for POST /api/tournaments/:id/draft and draft-state
# If secret contains #, wrap in quotes: MAJOR_PAIN_WRITE_SECRET="your-secret#here"
MAJOR_PAIN_WRITE_SECRET=your-secret-here
# Same value for client (required for draft save from browser)
NEXT_PUBLIC_MAJOR_PAIN_WRITE_SECRET=your-secret-here

# API Configuration
# Set to 'true' to use database via API routes (recommended for local dev and production)
# Set to 'false' to use in-memory dummy data (no database required)
NEXT_PUBLIC_USE_API_CLIENT=true

# API URL - base path for API routes (same origin)
NEXT_PUBLIC_API_URL=/api

# RapidAPI Live Golf Data - required for live field import (admin: Import from Live API)
# Get key at https://rapidapi.com - subscribe to "Live Golf Data" API
RAPIDAPI_KEY=

# OneSignal Push Notifications - from OneSignal dashboard Settings > Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
# Safari Web ID - from OneSignal dashboard (Web configuration)
NEXT_PUBLIC_ONESIGNAL_SAFARI_WEB_ID=web.onesignal.auto.xxxxxxxx
# REST API Key - server-side only, for sending notifications
ONESIGNAL_REST_API_KEY=your-rest-api-key

# Dev only: set to 'true' to bypass native permission UI for testing OneSignal (or use ?notifications_test in URL)
# NEXT_PUBLIC_NOTIFICATIONS_DEV_TEST=true
